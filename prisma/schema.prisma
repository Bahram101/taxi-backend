generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id     String  @id @default(uuid())
  phone  String  @unique
  name   String
  role   Role
  avatar String?
  email  String?
  rating Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver?
  orders Order[]
  refreshTokens RefreshToken[]
}

model Driver {
  id        String  @id @default(uuid())
  userId    String  @unique
  carModel  String?
  carNumber String?
  isOnline  Boolean @default(false)
  rating    Float   @default(5.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

model Order {
  id          String      @id @default(uuid())
  clientId    String
  driverId    String?
  fromAddress String
  toAddress   String
  status      OrderStatus
  fromLat     Float
  fromLng     Float
  price       Decimal?
  toLat       Float
  toLng       Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User    @relation(fields: [clientId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([phone])
}

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum OrderStatus {
  NEW
  ACCEPTED
  ARRIVED
  STARTED
  COMPLETED
  CANCELLED
}

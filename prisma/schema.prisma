generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver?
  orders Order[]
}

model Driver {
  id        String   @id @default(uuid())
  userId    String   @unique
  carModel  String
  carNumber String
  rating    Float    @default(5.0)
  isOnline  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

model Order {
  id String @id @default(uuid())

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  fromAddress String
  fromLat     Float
  fromLng     Float
  toAddress   String
  toLat       Float
  toLng       Float

  price  Decimal?
  status OrderStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum OrderStatus {
  NEW
  ACCEPTED
  ARRIVED
  STARTED
  COMPLETED
  CANCELLED
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}
